REACT_APP_RAPIDAPI_KEY=your_rapidapi_key_here
REACT_APP_CONVERTAPI_SECRET=your_convertapi_secret_here
REACT_APP_REMOVEBG_API_KEY=your_removebg_api_key_here

# Stripe (frontend — publishable key only)
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# Stripe (backend — keep secret, never commit .env)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_MONTHLY_PRODUCT_ID=prod_your_monthly_id
STRIPE_YEARLY_PRODUCT_ID=prod_your_yearly_id

# PayPal (backend — keep secret, never commit .env)
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox
# Optional: set after creating plans in PayPal dashboard
# PAYPAL_PRODUCT_ID=
# PAYPAL_MONTHLY_PLAN_ID=
# PAYPAL_YEARLY_PLAN_ID=

CLIENT_URL=http://localhost:3000
PORT=4242
